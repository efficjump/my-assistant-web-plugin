{
  "manifest_version": 3,
  "name": "My Assistant Web Plugin",
  "version": "0.9.8",
  "description": "A verifiable AI browser agent with structured planning, guarded tool use, action approval, and outcome checks.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Open web assistant"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "optional_permissions": [
    "downloads",
    "identity"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "side_panel": {
    "default_path": "panel.html"
  }
}
